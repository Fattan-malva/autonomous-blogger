{
  "name": "autonomous-blogger-seo-business",
  "version": "1.0.0",
  "description": "Fully autonomous publishing business that discovers topics, generates content, publishes to Blogger, and monetizes with Adsterra",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "worker": "ts-node src/workers/index.ts",
    "scheduler": "ts-node src/services/scheduler/index.ts",
    "trigger": "node dist/trigger.js",
    "test": "ts-node src/test.ts",
    "migrate": "ts-node src/database/migrate.ts",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "bullmq": "^5.12.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.0",
    "drizzle-orm": "^0.33.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "googleapis": "^140.0.0",
    "cheerio": "^1.0.0",
    "axios": "^1.7.7",
    "winston": "^3.14.0",
    "zod": "^3.23.8",
    "pino": "^9.4.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.2",
    "ts-node": "^10.9.2",
    "drizzle-kit": "^0.24.0",
    "eslint": "^9.10.0"
  }
}
