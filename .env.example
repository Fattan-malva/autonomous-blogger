NODE_ENV=production
PORT=3000

DATABASE_URL=postgres://blogger:blogger_password@postgres:5432/blogger_seo
REDIS_URL=redis://redis:6379

GOOGLE_AI_API_KEY=your_gemini_api_key_here
GOOGLE_AI_MODEL=gemma-4-26b-a4b-it

BLOGGER_BLOG_ID=your_blog_id
BLOGGER_CLIENT_ID=your_client_id
BLOGGER_CLIENT_SECRET=your_client_secret
BLOGGER_REFRESH_TOKEN=your_refresh_token

SEARCH_CONSOLE_CLIENT_ID=your_sc_client_id
SEARCH_CONSOLE_CLIENT_SECRET=your_sc_client_secret
SEARCH_CONSOLE_REFRESH_TOKEN=your_sc_refresh_token

# Adsterra API Token (cari di Settings > API)
# Semua script iklan akan digenerate otomatis dari 1 token ini
ADSTERRA_API_TOKEN=

LOG_LEVEL=info
